{
  "name": "agent-browser-wallet",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "docs:assets": "node scripts/capture-readme-assets.mjs",
    "docs:assets:real-sepolia": "node scripts/capture-real-sepolia-readme-asset.mjs",
    "wallet:smoke:metamask": "pnpm --filter @agent-browser-wallet/fixture-dapp build && pnpm --filter @agent-browser-wallet/wallet-browser build && node packages/wallet-browser/dist/cli.js smoke-metamask",
    "wallet:smoke:fixture-extension": "pnpm --filter @agent-browser-wallet/wallet-browser build && node packages/wallet-browser/dist/cli.js smoke-fixture-extension",
    "wallet:smoke:verify": "pnpm --filter @agent-browser-wallet/wallet-browser build && node packages/wallet-browser/dist/cli.js verify-smoke-artifacts",
    "wallet:metamask:fetch": "python3 scripts/fetch-metamask-extension.py",
    "security:scan": "python3 scripts/sensitive-scan.py",
    "fixture:build": "pnpm --filter @agent-browser-wallet/fixture-dapp build",
    "fixture:test": "pnpm --filter @agent-browser-wallet/fixture-dapp test",
    "fixture:test:mocked-provider": "pnpm --filter @agent-browser-wallet/fixture-dapp test:mocked-provider",
    "fixture:serve": "pnpm --filter @agent-browser-wallet/fixture-dapp serve",
    "wallet:live:fixture-connect": "node scripts/live-fixture-connect.mjs",
    "wallet:live:wildcat-connect": "node scripts/live-wildcat-connect.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
