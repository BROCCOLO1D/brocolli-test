{
  "name": "brocolli-test",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "wallet:cli": "pnpm --filter @broccolo1d/wallet-browser build && node packages/wallet-browser/dist/cli.js",
    "wallet:doctor": "pnpm --filter @broccolo1d/wallet-browser build && node packages/wallet-browser/dist/cli.js doctor",
    "wallet:prepare": "pnpm --filter @broccolo1d/wallet-browser build && node packages/wallet-browser/dist/cli.js prepare",
    "wallet:smoke:metamask": "pnpm --filter @broccolo1d/wallet-browser build && node packages/wallet-browser/dist/cli.js smoke-metamask",
    "wallet:smoke:fixture-extension": "pnpm --filter @broccolo1d/wallet-browser build && node packages/wallet-browser/dist/cli.js smoke-fixture-extension",
    "wallet:smoke:verify": "pnpm --filter @broccolo1d/wallet-browser build && node packages/wallet-browser/dist/cli.js verify-smoke-artifacts",
    "wallet:metamask:fetch": "python3 scripts/fetch-metamask-extension.py",
    "verify:playwright-consumer": "node scripts/verify-playwright-consumer.mjs",
    "verify:playwright-release": "node scripts/verify-playwright-release-readiness.mjs",
    "publish:playwright": "node scripts/publish-playwright.mjs",
    "security:scan": "python3 scripts/sensitive-scan.py"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
