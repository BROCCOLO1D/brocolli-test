{
  "name": "@brocolli-test/playwright",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "pnpm --filter @brocolli-test/wallet-browser build && tsc -p tsconfig.json",
    "test": "pnpm --filter @brocolli-test/wallet-browser build && vitest run",
    "typecheck": "pnpm --filter @brocolli-test/wallet-browser build && tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@playwright/test": "^1.59.1"
  },
  "dependencies": {
    "@brocolli-test/wallet-browser": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.0",
    "vitest": "4.1.5"
  }
}
