{
  "name": "@broccolo1d/playwright",
  "version": "0.2.10",
  "description": "Playwright fixtures for policy-gated browser-wallet dapp QA.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/BROCCOLO1D/brocolli-test#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BROCCOLO1D/brocolli-test.git",
    "directory": "packages/playwright"
  },
  "bugs": {
    "url": "https://github.com/BROCCOLO1D/brocolli-test/issues"
  },
  "keywords": [
    "playwright",
    "metamask",
    "wallet",
    "dapp",
    "qa",
    "ethereum",
    "fixtures"
  ],
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "pnpm --filter @broccolo1d/wallet-browser build && tsc -p tsconfig.json",
    "test": "pnpm --filter @broccolo1d/wallet-browser build && vitest run",
    "typecheck": "pnpm --filter @broccolo1d/wallet-browser build && tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@playwright/test": "^1.59.1"
  },
  "dependencies": {
    "@broccolo1d/wallet-browser": "^0.2.8"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.0",
    "vitest": "4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
