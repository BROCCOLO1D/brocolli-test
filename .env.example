# Local Sepolia burner wallet configuration.
# Copy to .env and fill with non-production testnet values only.

SEPOLIA_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
SEPOLIA_WALLET_PRIVATE_KEY=replace-with-testnet-burner-private-key
SEPOLIA_RPC_URL=https://sepolia.example.invalid
SEPOLIA_CHAIN_ID=11155111
METAMASK_PASSWORD=replace-with-local-wallet-password

# Local fixture and wallet-browser runtime defaults.
FIXTURE_DAPP_URL=http://127.0.0.1:5173
WALLET_PROFILE_NAME=sepolia-burner
WALLET_PROFILE_DIR=.wallet-profiles/sepolia-burner
METAMASK_EXTENSION_DIR=.wallet-extensions/metamask
PRESERVE_WALLET_PROFILE=false
WALLET_TRACE_MODE=off
